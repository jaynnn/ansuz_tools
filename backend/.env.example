PORT=4000
JWT_SECRET=your-secret-jwt-key-here
DATABASE_PATH=./database.sqlite
LLM_API_KEY=your-deepseek-api-key-here
LLM_API_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_AUDIO_MODEL=glm-4-flash
MONGODB_URI=mongodb://localhost:27017/mindsea
# Optional: Restrict CORS to specific origins (comma-separated)
# CORS_ORIGIN=https://yourdomain.com
# Optional: Timezone for bot log display in LLM context (default: Asia/Shanghai)
# SERVER_TIMEZONE=Asia/Shanghai
# Optional: Override AI trading bot decision interval in milliseconds (default: 600000 = 10 minutes)
# STOCK_BOT_INTERVAL_MS=600000
